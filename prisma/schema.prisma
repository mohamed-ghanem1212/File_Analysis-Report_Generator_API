generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(uuid())
  email     String      @unique
  username  String
  password  String
  role      Role        @default(USER)
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  analyses  Analysis[]
  comments  Comment[]
  debtItems Debt_Item[]
  issues    Issue[]
  projects  Project[]
  reports   Report[]
}

model Project {
  id            String        @id @default(uuid())
  userId        String
  name          String
  description   String?
  repositoryUrl String
  branch        String        @default("main")
  language      Language
  visibility    Visibility    @default(PRIVATE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  settings      Json          @default("{}")
  analyses      Analysis[]
  debtItems     Debt_Item[]
  metrics       Metric[]
  user          User          @relation(fields: [userId], references: [id])
 
}

model Analysis {
  id              String         @id @default(uuid())
  projectId       String
  userId          String
  status          AnalysisStatus @default(PENDING)
  trigger         TriggerType    @default(MANUAL)
  branch          String
  commitHash      String?
  summary         Json           @default("{}")
  totalFiles      Int            @default(0)
  totalLines      Int            @default(0)
  issuesFound     Int            @default(0)
  complexityScore Float          @default(0)
  startedAt       DateTime       @default(now())
  completedAt     DateTime?
  project         Project        @relation(fields: [projectId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
  files           File[]
  issues          Issue[]
  metrics         Metric[]
  reports         Report[]
}

model File {
  id              String   @id @default(uuid())
  analysisId      String
  filePath        String
  fileName        String
  fileExtension   String
  fileHash        String
  linesOfCode     Int
  lineBlank       Int
  lineComment     Int
  issuesFound     Int
  complexityScore Float
  analysis        Analysis @relation(fields: [analysisId], references: [id])
  issues          Issue[]
}

model Issue {
  id              String      @id @default(uuid())
  fileId          String
  analysisId      String
  category        Category    @default(CODE_SMELL)
  severity        Severity    @default(LOW)
  title           String
  description     String
  lineNumber      Int
  columnNumber    Int
  codeSnippet     String
  suggestion      String?
  isResolved      Boolean     @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?
  debtItems       Debt_Item[]
  analysis        Analysis    @relation(fields: [analysisId], references: [id])
  file            File        @relation(fields: [fileId], references: [id])
  resolvedBy      User?       @relation(fields: [resolvedById], references: [id])
}

model Metric {
  id         String     @id @default(uuid())
  analysisId String
  projectId  String
  name       String
  value      Float
  unit       String
  type       MetricType
  metaData   Json       @default("{}")
  analysis   Analysis   @relation(fields: [analysisId], references: [id])
  project    Project    @relation(fields: [projectId], references: [id])
}

model Report {
  id          String     @id @default(uuid())
  analysisId  String
  userId      String
  reportType  ReportType @default(SUMMARY)
  format      Format     @default(JSON)
  content     Json       @default("{}")
  filePath    String?
  downloadUrl String?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  analysis    Analysis   @relation(fields: [analysisId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
}



model Debt_Item {
  id              String    @id @default(uuid())
  projectId       String
  issueId         String
  title           String
  description     String
  priority        Severity  @default(MEDIUM)
  status          Status    @default(IDENTIFIED)
  estimatedEffort Int
  businessImpact  Float     @default(0)
  assignedToId    String?
  dueDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  assignedTo      User?     @relation(fields: [assignedToId], references: [id])
  issue           Issue     @relation(fields: [issueId], references: [id])
  project         Project   @relation(fields: [projectId], references: [id])
}

model Comment {
  id              String   @id @default(uuid())
  userId          String
  commentableType String
  commentableId   String
  content         String
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}



// ────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum Language {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  PHP
  JAVA
  GO
  RUBY
  CSHARP
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum TriggerType {
  MANUAL
  SCHEDULED
  WEBHOOK
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Category {
  CODE_SMELL
  BUG_RISK
  PERFORMANCE
  SECURITY
  STYLE
  COMPLEXITY
  DUPLICATION
  TECHNICAL_DEBT
}

enum MetricType {
  CODE_COVERAGE
  DUPLICATION
  COMPLEXITY
  SECURITY_VULNERABILITIES
  STYLE_VIOLATIONS
  TECHNICAL_DEBT
}

enum ReportType {
  SUMMARY
  DETAILED
  EXECUTIVE
  COMPARISON
  TREND
}

enum Format {
  JSON
  PDF
  HTML
  MARKDOWN
}

enum Status {
  IDENTIFIED
  ACKNOWLEDGED
  PLANNED
  IN_PROGRESS
  RESOLVED
  WONT_FIX
}

enum Action {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}
